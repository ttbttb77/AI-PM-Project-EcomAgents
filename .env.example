# ============================================================
# 电商多Agent系统 — 环境变量配置
# 复制此文件为 .env 并填入真实值
# ============================================================

# -----------------------------------------------------------
# LLM API 密钥
# -----------------------------------------------------------
# DeepSeek API（主模型）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 阿里通义千问 API（备用模型）
DASHSCOPE_API_KEY=sk-your-dashscope-api-key

# -----------------------------------------------------------
# 电商平台 API
# -----------------------------------------------------------
# 淘宝开放平台
TAOBAO_APP_KEY=your-app-key
TAOBAO_APP_SECRET=your-app-secret
TAOBAO_API_URL=https://eco.taobao.com/router/rest

# 京东开放平台
JD_APP_KEY=your-app-key
JD_APP_SECRET=your-app-secret
JD_API_URL=https://api.jd.com/routerjson

# 抖音开放平台
DOUYIN_APP_KEY=your-app-key
DOUYIN_APP_SECRET=your-app-secret
DOUYIN_API_URL=https://open.douyin.com/api

# -----------------------------------------------------------
# 向量数据库（RAG 检索）
# -----------------------------------------------------------
MILVUS_HOST=localhost
MILVUS_PORT=19530
# 或使用 Chroma
# CHROMA_URL=http://localhost:8000

# -----------------------------------------------------------
# 通知渠道
# -----------------------------------------------------------
# 飞书机器人 Webhook
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook

# 钉钉机器人 Webhook
DINGTALK_WEBHOOK_URL=https://oapi.dingtalk.com/robot/send?access_token=your-token

# -----------------------------------------------------------
# 系统配置
# -----------------------------------------------------------
# 日志级别: trace / debug / info / warn / error / fatal
LOG_LEVEL=info

# 数据存储路径
DATA_DIR=./data

# 日志存储路径
LOG_DIR=./logs

# -----------------------------------------------------------
# 安全
# -----------------------------------------------------------
# JWT 密钥
JWT_SECRET=your-jwt-secret-change-in-production

# 加密密钥（AES-256）
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# 会话有效期（毫秒）
SESSION_TTL=86400000
